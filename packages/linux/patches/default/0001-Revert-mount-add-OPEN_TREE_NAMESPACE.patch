From ea44632734092034b16ebf840afef38808f48ffc Mon Sep 17 00:00:00 2001
From: Rudi Heitbaum <rudi@heitbaum.com>
Date: Tue, 24 Feb 2026 17:19:03 +0000
Subject: [PATCH] Revert "mount: add OPEN_TREE_NAMESPACE"

This reverts commit 9b8a0ba68246a61d903ce62c35c303b1501df28b.
---
 include/uapi/linux/mount.h | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/include/uapi/linux/mount.h b/include/uapi/linux/mount.h
index d9d86598d100..3d7acc80a90c 100644
--- a/include/uapi/linux/mount.h
+++ b/include/uapi/linux/mount.h
@@ -61,7 +61,7 @@
 /*
  * open_tree() flags.
  */
-#define OPEN_TREE_CLONE		(1 << 0)	/* Clone the target tree and attach the clone */
+#define OPEN_TREE_CLONE		1		/* Clone the target tree and attach the clone */
 #define OPEN_TREE_NAMESPACE	(1 << 1)	/* Clone the target tree into a new mount namespace */
 #define OPEN_TREE_CLOEXEC	O_CLOEXEC	/* Close the file on execve() */
 

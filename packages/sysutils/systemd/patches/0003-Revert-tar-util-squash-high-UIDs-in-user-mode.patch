From 70408d505797cf6d195f8613750521bcbc5d65b6 Mon Sep 17 00:00:00 2001
From: Rudi Heitbaum <rudi@heitbaum.com>
Date: Thu, 27 Nov 2025 13:27:42 +0000
Subject: [PATCH 3/4] Revert "tar-util: squash high UIDs in user mode"

This reverts commit 78a738f4cf98ee7731b173ac0b4993ec9a88489a.
---
 src/import/import-common.c |  8 +---
 src/shared/tar-util.c      | 93 ++++++++++++--------------------------
 src/shared/tar-util.h      |  3 +-
 3 files changed, 32 insertions(+), 72 deletions(-)

diff --git a/src/import/import-common.c b/src/import/import-common.c
index 2fb781442a..11a6c060bb 100644
--- a/src/import/import-common.c
+++ b/src/import/import-common.c
@@ -35,9 +35,7 @@ int import_fork_tar_x(int tree_fd, int userns_fd, PidRef *ret_pid) {
         if (r < 0)
                 return r;
 
-        TarFlags flags =
-                (userns_fd >= 0 ? TAR_SQUASH_UIDS_ABOVE_64K : 0) |
-                (mac_selinux_use() ? TAR_SELINUX : 0);
+        TarFlags flags = mac_selinux_use() ? TAR_SELINUX : 0;
 
         _cleanup_close_pair_ int pipefd[2] = EBADF_PAIR;
         if (pipe2(pipefd, O_CLOEXEC) < 0)
@@ -102,9 +100,7 @@ int import_fork_tar_c(int tree_fd, int userns_fd, PidRef *ret_pid) {
         if (r < 0)
                 return r;
 
-        TarFlags flags =
-                (userns_fd >= 0 ? TAR_SQUASH_UIDS_ABOVE_64K : 0) |
-                (mac_selinux_use() ? TAR_SELINUX : 0);
+        TarFlags flags = mac_selinux_use() ? TAR_SELINUX : 0;
 
         _cleanup_close_pair_ int pipefd[2] = EBADF_PAIR;
         if (pipe2(pipefd, O_CLOEXEC) < 0)
diff --git a/src/shared/tar-util.c b/src/shared/tar-util.c
index 05dd4cd9fc..a4d0578b25 100644
--- a/src/shared/tar-util.c
+++ b/src/shared/tar-util.c
@@ -18,7 +18,6 @@
 #include "iovec-util.h"
 #include "libarchive-util.h"
 #include "mountpoint-util.h"
-#include "nsresource.h"
 #include "nulstr-util.h"
